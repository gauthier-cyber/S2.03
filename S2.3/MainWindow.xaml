<Window x:Class="S2._3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:S2._3"
        mc:Ignorable="d"
        Title="@IPV4" Height="450" Width="400">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="10*"/>
            <ColumnDefinition Width="17*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <TextBlock Text="Décimal" HorizontalAlignment="Center" VerticalAlignment="Center"
                   Grid.Column="0" Grid.Row="0"/>
        <TextBox x:Name="TxtDec" BorderBrush="Black" BorderThickness="1" Margin="10" Width="120"
                 HorizontalAlignment="Left" Text="Adresse IPv4 (déc.)" Foreground="Gray"
                 Grid.Column="1" Grid.Row="0" Background="#FFDADADA" MaxLength="15"
                 GotFocus="TxtBox_GotFocus" LostFocus="TxtBox_LostFocus" PreviewTextInput="TxtBox_PreviewTextInput"/>
        <TextBox x:Name="TxtCIDR" BorderBrush="Black" BorderThickness="1" Margin="10" Width="50"
                 HorizontalAlignment="Right" Text="/CIDR" Foreground="Gray"
                 Grid.Column="1" Grid.Row="0" Background="#FFDADADA" MaxLength="3"
                 GotFocus="TxtBox_GotFocus" LostFocus="TxtBox_LostFocus" PreviewTextInput="TxtBox_PreviewTextInput"/>

        <TextBlock Text="Binaire" HorizontalAlignment="Center" VerticalAlignment="Center" 
                   Grid.Column="0" Grid.Row="1"/>
        <TextBox x:Name="TxtBin" BorderBrush="Black" BorderThickness="1" Margin="10"
                 Text="Adresse IPv4 (binaire)" Foreground="Gray"
                 Grid.Column="1" Grid.Row="1" Background="#FFDADADA" MaxLength="35"
                 GotFocus="TxtBox_GotFocus" LostFocus="TxtBox_LostFocus" PreviewTextInput="TxtBox_PreviewTextInput"/>

        <TextBlock Text="Masque standard" HorizontalAlignment="Center" VerticalAlignment="Center"
                   Grid.Column="0" Grid.Row="2"/>
        <TextBox x:Name="TxtMask" BorderBrush="Black" BorderThickness="1" Margin="10"
                 Text="Masque standard (déc.)" Foreground="Gray"
                 Grid.Column="1" Grid.Row="2" Background="#FFDADADA" MaxLength="15"
                 GotFocus="TxtBox_GotFocus" LostFocus="TxtBox_LostFocus" PreviewTextInput="TxtBox_PreviewTextInput"/>

        <Button x:Name="BtnCalcul" Content="Calculer" HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="60" Height="20" Click="BtnCalcul_Click"
                Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="3"/>
        <Button x:Name="BtnReset" Content="Réinitialiser" HorizontalAlignment="Right" VerticalAlignment="Center"
                Width="80" Height="20" Click="BtnReset_Click"
                Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="3" Margin="0,0,100,0" Visibility="Hidden"/>

        <Separator Margin="10,0,10,35" Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="4" BorderBrush="Black" BorderThickness="1"/>

        <TextBlock Text="Adresse de classe : " FontWeight="Bold"
                   VerticalAlignment="Center" HorizontalAlignment="Left" Margin="15,0,0,0"
                   Grid.Column="0" Grid.Row="4"/>
        <TextBlock Text="Adresse de réseau : " FontWeight="Bold"
                   VerticalAlignment="Center" HorizontalAlignment="Left" Margin="15,0,0,0"
                   Grid.Column="0" Grid.Row="5"/>
        <TextBlock Text="Première adresse : " FontWeight="Bold"
                   VerticalAlignment="Center" HorizontalAlignment="Left" Margin="15,0,0,0"
                   Grid.Column="0" Grid.Row="6"/>
        <TextBlock Text="Dernière adresse : " FontWeight="Bold"
                   VerticalAlignment="Center" HorizontalAlignment="Left" Margin="15,0,0,0"
                   Grid.Column="0" Grid.Row="7"/>
        <TextBlock Text="Adresse de broadcast : " FontWeight="Bold"
                   VerticalAlignment="Center" HorizontalAlignment="Left" Margin="15,0,0,0"
                   Grid.Column="0" Grid.Row="8"/>
        <TextBlock Text="Nombre d'IP : " FontWeight="Bold"
                   VerticalAlignment="Center" HorizontalAlignment="Left" Margin="15,0,0,0"
                   Grid.Column="0" Grid.Row="9"/>
        <TextBlock Text="Nombre de machines : " FontWeight="Bold"
                   VerticalAlignment="Center" HorizontalAlignment="Left" Margin="15,0,0,0"
                   Grid.Column="0" Grid.Row="10"/>

        <TextBlock x:Name="TxtClass" Grid.Column="1" Grid.Row="4" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0"/>
        <TextBlock x:Name="TxtNetwork" Grid.Column="1" Grid.Row="5" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0"/>
        <TextBlock x:Name="TxtFirstIP" Grid.Column="1" Grid.Row="6" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0"/>
        <TextBlock x:Name="TxtLastIP" Grid.Column="1" Grid.Row="7" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0"/>
        <TextBlock x:Name="TxtBroadcast" Grid.Column="1" Grid.Row="8" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0"/>
        <TextBlock x:Name="TxtIP" Grid.Column="1" Grid.Row="9" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0"/>
        <TextBlock x:Name="TxtMachines" Grid.Column="1" Grid.Row="10" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10,0,0,0"/>
    </Grid>
</Window>
